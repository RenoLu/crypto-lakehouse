# Binance API (public endpoints, no key needed for market data)
BINANCE_BASE_URL=https://data-api.binance.vision

# DuckDB
DUCKDB_PATH=./data/duckdb/lakehouse.duckdb

# Lakehouse paths
LAKEHOUSE_ROOT=./data/lakehouse

# Ollama (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# Default symbols
DEFAULT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Default intervals
DEFAULT_INTERVALS=1m,5m,1h,1d

# Candle limit for ingestion
CANDLE_LIMIT=1000

# Server
API_HOST=0.0.0.0
API_PORT=8000

# Background polling (optional continuous data ingestion)
POLLING_ENABLED=false
POLLING_INTERVAL_SECONDS=60
